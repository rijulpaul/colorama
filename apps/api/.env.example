NODE_ENV=development
PORT=3001

# MongoDB
MONGODB_URI=mongodb://root:password@localhost:27017/colorama?authSource=admin

# Redis
REDIS_URL=redis://localhost:6379

# LangChain / LLM (defaults to Ollama when OPENAI_API_KEY is unset)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Optional: use OpenAI instead of Ollama
# OPENAI_API_KEY=sk-...
